---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
import IntroCard from "../components/IntroCard.astro";
import ContactsCard from "../components/ContactsCard.astro";
import AboutMe from "../components/AboutMe.astro";
import Now from "../components/Now.astro";
import Globe from "../components/Globe";
import { getCollection } from "astro:content";
import { formatDate } from "../lib/helpers";

const posts = (await getCollection("blog"))?.sort(
  (blogEntryA, blogEntryB) =>
    (blogEntryB.data.pubDate || new Date()).getTime() -
    (blogEntryA.data.pubDate || new Date()).getTime()
);
---

<script>
  import { stagger, animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";

  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        type: "spring",
        at: "-0.1",
        delay: stagger(0.3),
      },
    ],
  ];

  // ── Wiggle helper ──────────────────────────────────────────────────────────
  // Removes any in-flight wiggle class, forces a reflow so the browser
  // registers the removal, then re-adds it.  The `animationend` listener
  // cleans up with { once: true } so repeated hovers always retrigger cleanly.
  function triggerWiggle(el: HTMLElement | null): void {
    if (!el) return;
    el.classList.remove("wiggle");
    void el.offsetWidth; // force reflow
    el.classList.add("wiggle");
    el.addEventListener("animationend", () => el.classList.remove("wiggle"), {
      once: true,
    });
  }

  const devDiaryCard = document.getElementById("dev-diary-card");

  // Hover: retrigger on every mouseenter
  devDiaryCard?.addEventListener("mouseenter", () =>
    triggerWiggle(devDiaryCard)
  );

  // On-load: fire wiggle once the entrance animation sequence has finished
  const controls = animate(sequence as AnimationSequence);
  controls.finished.then(() => triggerWiggle(devDiaryCard));
</script>

<!--
  Wiggle animation for the Dev Diary card.

  • @keyframes wiggle  — subtle horizontal oscillation (±5 px max) that damps
    to rest over 0.5 s.  The final frame is translateX(0) which matches the
    default resting position, so there is no visual snap when the animation
    ends — even if Motion.js left a residual inline translateY(0%) style from
    the entrance sequence.

  • :global(#dev-diary-card.wiggle) — Astro scopes <style> blocks to the
    current component by default.  Because the `.wiggle` class is added to a
    <div> that lives inside the child <Card> component, we must opt out of
    scoping for this one rule so it reaches across the component boundary.
-->
<style>
  @keyframes wiggle {
    0%   { transform: translateX(0); }
    15%  { transform: translateX(-5px); }
    30%  { transform: translateX(4px); }
    45%  { transform: translateX(-3px); }
    60%  { transform: translateX(2px); }
    75%  { transform: translateX(-1px); }
    100% { transform: translateX(0); }
  }

  :global(#dev-diary-card.wiggle) {
    animation: wiggle 0.5s ease-in-out;
  }
</style>

<Layout
  description="I'm a developer based in NYC, passionate about finance, tech, and their intersecton."
  title="Juan Diego Meza - Full-stack Software Developer"
>
  <main
    class="text-black dark:text-white m-auto p-2 grid gap-2 max-w-6xl overflow-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px]"
  >
    <IntroCard />
    <AboutMe />
    <ContactsCard />
    <Now />
    <Card
      colorText="text-black dark:text-white"
      colSpan="md:col-span-2"
      href="travel"
      rowSpan="md:row-span-4"
    >
      <h1 class="text-black dark:text-white text-xl font-bold p-4">Travel Map</h1>
      <div class="h-full w-full absolute inset-20 -z-30">
        <Globe client:load />
      </div>
    </Card>
    <Card
      id="dev-diary-card"
      colSpan="md:col-span-1"
      href="/blog"
      rowSpan="md:row-span-4 flex gap-1"
    >
      <div class="flex flex-col gap-1 p-4">
        <h1 class="text-black dark:text-white text-xl font-bold">Dev Diary</h1>
        {
          posts?.slice(0, 5).map((post) => (
            // <a
            //   class="text-sm md:text-base decoration-none flex justify-between"
            //   href={`/blog/${post.id}`}
            // >
            <div class="list-none w-full text-black dark:text-white hover:text-neutral-400 ease-in-out transition-colors border-b-neutral-400 border-dashed border-b-1 my-0">
              <p class="inline-block whitespace-nowrap text-xs">
                {post.data.title}
              </p>
              <br>
            </div>
            // </a>
          ))
        }
      </div>
    </Card>
  </main>
</Layout>
