---
import { Image } from "astro:assets";
import Vinyl from "../components/Vinyl.astro";
import BasicLayout from "../layouts/BasicLayout.astro";
import albumData from "../data/vinyls/albums/details.json";

const albumCoverModules = import.meta.glob<{ default: ImageMetadata }>(
  "../data/vinyls/images/albumCovers/*",
  { eager: true }
);

const vinylLabelModules = import.meta.glob<{ default: ImageMetadata }>(
  "../data/vinyls/images/vinylLabels/*",
  { eager: true }
);

const albums = albumData.map((album) => {
  const albumFilename = album.albumImage.split("/").pop();
  const vinylFilename = album.vinylImage.split("/").pop();
  const albumImg = albumCoverModules[`../data/vinyls/images/albumCovers/${albumFilename}`]?.default;
  const vinylImg = vinylLabelModules[`../data/vinyls/images/vinylLabels/${vinylFilename}`]?.default;
  return { ...album, albumImg, vinylImg };
});

// Mobile 3-row shelf split
const MOBILE_ROW = 3;
const mobileRow1 = albums.slice(0, MOBILE_ROW);
const mobileRow2 = albums.slice(MOBILE_ROW, MOBILE_ROW * 2);
const mobileRow3 = albums.slice(MOBILE_ROW * 2);
---

<script>
  import { animate, type AnimationSequence } from "motion";

  const sequence = [
    [
      ".loaderRef",
      { opacity: [1, 0], pointerEvents: "none" },
      { type: "spring", easing: "ease-out" },
    ],
  ];

  animate(sequence as AnimationSequence);
</script>

<BasicLayout
  description="A spinning vinyl disc and my record shelf"
  page="travel"
  title="Vinyls"
>
  <a
    class="text-black dark:text-white absolute hover:bg-neutral-800 top-4 left-4 px-4 py-2 border-1 border-solid border-neutral-600 rounded-lg z-10"
    href="/">Back</a
  >

  <div class="vinyls-page">
    <!-- Currently playing section -->
    <div class="now-playing">
      <p class="now-playing-label">currently playing on my turntable...</p>
      <a
        id="vinyl-link"
        href={albums[0].link}
        target="_blank"
        rel="noopener noreferrer"
        class="vinyl-stage"
      >
        <div id="vinyl-stage">
          <Vinyl vinylImageSrc={albums[0].vinylImg?.src} />
        </div>
      </a>
    </div>

    <!-- Record shelf -->
    <div class="shelf-section">
      <div class="shelf-header">
        <h2 class="shelf-title text-black dark:text-white">My Shelf</h2>
        <div class="shelf-nav">
          <button class="shelf-nav-btn" id="shelf-prev" aria-label="Scroll left">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="shelf-nav-btn" id="shelf-next" aria-label="Scroll right">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="shelf-scroll-wrapper">
        <div class="shelf-fade shelf-fade-left"></div>
        <div class="shelf" id="shelf-track">
          {albums.map((album, i) => (
            <div
              class={`record-sleeve${i === 0 ? " selected" : ""}`}
              style={`--sleeve-color: ${album.color}`}
              data-color={album.color}
              data-index={i}
              data-vinyl-image={album.vinylImg?.src ?? ""}
              data-link={album.link ?? ""}
            >
              {album.albumImg && (
                <Image
                  src={album.albumImg}
                  alt={`${album.title} by ${album.artist}`}
                  class="sleeve-image"
                  width={120}
                  height={120}
                />
              )}
              <div class="sleeve-face">
                <p class="sleeve-title">{album.title}</p>
                <p class="sleeve-artist">{album.artist}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="shelf-fade shelf-fade-right"></div>
      </div>
      <div class="shelf-board" />
    </div>

    <!-- Mobile shelves: 3 rows, mobile only -->
    <div class="mobile-shelves">
      <div class="shelf-header">
        <h2 class="shelf-title text-black dark:text-white">My Shelf</h2>
      </div>

      <!-- Row 1 -->
      <div class="mobile-shelf-row">
        <div class="shelf shelf-no-scroll">
          {mobileRow1.map((album, localIdx) => (
            <div
              class={`record-sleeve${localIdx === 0 ? " selected" : ""}`}
              style={`--sleeve-color: ${album.color}`}
              data-color={album.color}
              data-index={localIdx}
              data-vinyl-image={album.vinylImg?.src ?? ""}
              data-link={album.link ?? ""}
            >
              {album.albumImg && (
                <Image
                  src={album.albumImg}
                  alt={`${album.title} by ${album.artist}`}
                  class="sleeve-image"
                  width={96}
                  height={96}
                />
              )}
              <div class="sleeve-face">
                <p class="sleeve-title">{album.title}</p>
                <p class="sleeve-artist">{album.artist}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="shelf-board" />
      </div>

      <!-- Row 2 -->
      <div class="mobile-shelf-row">
        <div class="shelf shelf-no-scroll">
          {mobileRow2.map((album, localIdx) => (
            <div
              class="record-sleeve"
              style={`--sleeve-color: ${album.color}`}
              data-color={album.color}
              data-index={MOBILE_ROW + localIdx}
              data-vinyl-image={album.vinylImg?.src ?? ""}
              data-link={album.link ?? ""}
            >
              {album.albumImg && (
                <Image
                  src={album.albumImg}
                  alt={`${album.title} by ${album.artist}`}
                  class="sleeve-image"
                  width={96}
                  height={96}
                />
              )}
              <div class="sleeve-face">
                <p class="sleeve-title">{album.title}</p>
                <p class="sleeve-artist">{album.artist}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="shelf-board" />
      </div>

      <!-- Row 3 (slider for remaining albums) -->
      <div class="mobile-shelf-row">
        <div class="shelf-scroll-wrapper">
          <div class="shelf-fade shelf-fade-left" id="m-fade-left"></div>
          <div class="shelf" id="mobile-shelf-track">
            {mobileRow3.map((album, localIdx) => (
              <div
                class="record-sleeve"
                style={`--sleeve-color: ${album.color}`}
                data-color={album.color}
                data-index={MOBILE_ROW * 2 + localIdx}
                data-vinyl-image={album.vinylImg?.src ?? ""}
                data-link={album.link ?? ""}
              >
                {album.albumImg && (
                  <Image
                    src={album.albumImg}
                    alt={`${album.title} by ${album.artist}`}
                    class="sleeve-image"
                    width={96}
                    height={96}
                  />
                )}
                <div class="sleeve-face">
                  <p class="sleeve-title">{album.title}</p>
                  <p class="sleeve-artist">{album.artist}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="shelf-fade shelf-fade-right" id="m-fade-right"></div>
        </div>
        <div class="shelf-board" />
      </div>
    </div>
  </div>
</BasicLayout>

<style>
  .vinyls-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    padding: 5rem 1.5rem 3rem;
    width: 100%;
    max-width: 860px;
  }

  /* ── Now playing ── */
  .now-playing {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .now-playing-label {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: #6b7280;
    font-style: italic;
  }

  .vinyl-stage {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vinyl-stage :global(.vinyl-disc) {
    width: 60vmin;
    max-width: 420px;
    cursor: pointer;
    transition: filter 0.2s ease, transform 0.2s ease;
  }

  .vinyl-stage:hover :global(.vinyl-disc) {
    filter: drop-shadow(0 14px 36px var(--vinyl-label-color, rgba(0, 0, 0, 0.8))) brightness(1.1);
    transform: scale(1.03);
  }

  /* ── Shelf ── */
  .shelf-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .shelf-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .shelf-title {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .shelf-nav {
    display: flex;
    gap: 0.4rem;
  }

  .shelf-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid #4b5563;
    background: transparent;
    color: #9ca3af;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .shelf-nav-btn:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
    border-color: #9ca3af;
  }

  .shelf-scroll-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .shelf-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 48px;
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.2s ease;
  }

  .shelf-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--shelf-bg, #fff), transparent);
  }

  .shelf-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--shelf-bg, #fff), transparent);
  }

  :global(.dark) .shelf-fade-left {
    background: linear-gradient(to right, #171717, transparent);
  }

  :global(.dark) .shelf-fade-right {
    background: linear-gradient(to left, #171717, transparent);
  }

  .shelf {
    display: flex;
    gap: 1rem;
    align-items: flex-end;
    padding: 0.5rem 0.75rem 0;
    width: 100%;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.2) transparent;
  }

  .shelf::-webkit-scrollbar {
    height: 2px;
  }

  .shelf::-webkit-scrollbar-track {
    background: transparent;
  }

  .shelf::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.2);
    border-radius: 1px;
  }

  .shelf-board {
    width: 100%;
    height: 12px;
    background: linear-gradient(to bottom, #a07850, #7a5830);
    border-radius: 3px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.35);
  }

  /* ── Individual record sleeve ── */
  .record-sleeve {
    position: relative;
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    border-radius: 4px;
    background-color: var(--sleeve-color);
    box-shadow: 3px 3px 10px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }

  .record-sleeve:hover {
    transform: translateY(-8px) rotate(-2deg);
    box-shadow: 6px 10px 20px rgba(0, 0, 0, 0.5);
  }

  .record-sleeve.selected {
    transform: translateY(-10px);
    box-shadow: 0 0 0 3px var(--sleeve-color), 0 14px 28px rgba(0, 0, 0, 0.6);
  }

  .sleeve-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sleeve-face {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8px;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 60%);
  }

  .sleeve-title {
    font-size: 0.65rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sleeve-artist {
    font-size: 0.55rem;
    color: rgba(255,255,255,0.75);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Mobile shelves (3-row layout, hidden on desktop) ── */
  .mobile-shelves {
    display: none;
    width: 100%;
    flex-direction: column;
    gap: 1.25rem;
  }

  .mobile-shelf-row {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Static rows: let the selected lift show without clipping */
  .shelf-no-scroll {
    overflow: visible;
    padding-top: 0.75rem;
    justify-content: center;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .vinyls-page {
      padding: 6rem 1rem 3rem;
      gap: 2rem;
    }

    /* Slightly smaller disc so the shelf is still visible above the fold */
    .vinyl-stage :global(.vinyl-disc) {
      width: 52vmin;
      max-width: 280px;
    }

    .now-playing-label {
      font-size: 0.75rem;
      letter-spacing: 0.04em;
    }

    /* Smaller sleeves — still comfortable touch targets, more fit per screen */
    .record-sleeve {
      width: 96px;
      height: 96px;
    }

    /* Swap to mobile 3-row shelves, hide desktop single shelf */
    .shelf-section {
      display: none;
    }

    .mobile-shelves {
      display: flex;
    }

    /* Nav buttons are redundant on touch — hide them, rely on swipe + fades */
    .shelf-nav {
      display: none;
    }

    .shelf {
      /* Snap to each sleeve for a smoother swipe feel on mobile */
      scroll-snap-type: x mandatory;
      gap: 0.75rem;
      /* Extra top padding so the selected-sleeve lift isn't clipped */
      padding: 0.75rem 0.5rem 0;
    }

    /* Align row 3's first album directly below row 2's first album.
       Formula mirrors the flexbox centering offset of the static rows:
       left-pad = static-shelf-left-padding + (row-width - static-padding - 3×sleeve - 2×gap) / 2 */
    #mobile-shelf-track {
      justify-content: flex-start;
      padding-left: calc(0.5rem + (100% - 1rem - 3 * 96px - 2 * 0.75rem) / 2);
    }

    .record-sleeve {
      scroll-snap-align: start;
    }

    .shelf-fade {
      width: 32px;
    }

    .shelf-title {
      font-size: 1rem;
    }

    .shelf-board {
      height: 10px;
    }
  }
</style>

<script>
  const STORAGE_KEY  = "vinyl-selected-color";
  const INDEX_KEY    = "vinyl-selected-index";
  const IMAGE_KEY    = "vinyl-selected-image";
  const LINK_KEY     = "vinyl-selected-link";
  const vinylStage   = document.getElementById("vinyl-stage");
  const vinylLink    = document.getElementById("vinyl-link") as HTMLAnchorElement | null;
  const labelImg     = document.getElementById("vinyl-label-img") as SVGImageElement | null;
  const sleeves      = document.querySelectorAll<HTMLElement>(".record-sleeve");

  function applySelection(sleeve: HTMLElement) {
    const color      = sleeve.dataset.color ?? "";
    const vinylImage = sleeve.dataset.vinylImage ?? "";
    const link       = sleeve.dataset.link ?? "";

    if (vinylStage && color) {
      vinylStage.style.setProperty("--vinyl-label-color", color);
    }

    if (labelImg) {
      if (vinylImage) {
        labelImg.setAttribute("href", vinylImage);
        labelImg.style.display = "";
      } else {
        labelImg.setAttribute("href", "");
        labelImg.style.display = "none";
      }
    }

    if (vinylLink && link) {
      vinylLink.href = link;
    }
  }

  // Initialise selection by data-index (works across desktop + all mobile rows)
  const savedIndex    = parseInt(localStorage.getItem(INDEX_KEY) ?? "0", 10);
  const savedIndexStr = savedIndex.toString();
  let   targetSleeve: HTMLElement | undefined;

  sleeves.forEach((s) => {
    if (s.dataset.index === savedIndexStr) {
      s.classList.add("selected");
      if (!targetSleeve) targetSleeve = s;
    } else {
      s.classList.remove("selected");
    }
  });

  if (!targetSleeve) targetSleeve = sleeves[0] as HTMLElement | undefined;
  if (targetSleeve) {
    applySelection(targetSleeve);
    const initColor = targetSleeve.dataset.color ?? "";
    const initImage = targetSleeve.dataset.vinylImage ?? "";
    const initLink  = targetSleeve.dataset.link ?? "";
    if (initColor) localStorage.setItem(STORAGE_KEY, initColor);
    localStorage.setItem(IMAGE_KEY, initImage);
    localStorage.setItem(LINK_KEY, initLink);
  }

  sleeves.forEach((sleeve) => {
    sleeve.addEventListener("click", () => {
      const color = sleeve.dataset.color;
      const index = sleeve.dataset.index;
      const vinylImage = sleeve.dataset.vinylImage ?? "";
      const link = sleeve.dataset.link ?? "";
      if (color) localStorage.setItem(STORAGE_KEY, color);
      if (index !== undefined) localStorage.setItem(INDEX_KEY, index);
      localStorage.setItem(IMAGE_KEY, vinylImage);
      localStorage.setItem(LINK_KEY, link);
      // Mark all sleeves with the same data-index (desktop + every mobile row)
      sleeves.forEach((s) => {
        if (s.dataset.index === index) {
          s.classList.add("selected");
        } else {
          s.classList.remove("selected");
        }
      });
      applySelection(sleeve);
    });
  });

  // ── Shelf slider navigation ──
  const shelfTrack  = document.getElementById("shelf-track") as HTMLElement | null;
  const prevBtn     = document.getElementById("shelf-prev") as HTMLButtonElement | null;
  const nextBtn     = document.getElementById("shelf-next") as HTMLButtonElement | null;
  const fadeLeft    = document.querySelector<HTMLElement>(".shelf-fade-left");
  const fadeRight   = document.querySelector<HTMLElement>(".shelf-fade-right");

  const SCROLL_AMOUNT = 260; // px per button click

  function updateFades() {
    if (!shelfTrack) return;
    const { scrollLeft, scrollWidth, clientWidth } = shelfTrack;
    if (fadeLeft)  fadeLeft.style.opacity  = scrollLeft > 4 ? "1" : "0";
    if (fadeRight) fadeRight.style.opacity = scrollLeft + clientWidth < scrollWidth - 4 ? "1" : "0";
  }

  prevBtn?.addEventListener("click", () => {
    shelfTrack?.scrollBy({ left: -SCROLL_AMOUNT, behavior: "smooth" });
  });
  nextBtn?.addEventListener("click", () => {
    shelfTrack?.scrollBy({ left: SCROLL_AMOUNT, behavior: "smooth" });
  });

  shelfTrack?.addEventListener("scroll", updateFades, { passive: true });

  // ── Mobile row-3 slider fades ──
  const mobileShelfTrack = document.getElementById("mobile-shelf-track") as HTMLElement | null;
  const mFadeLeft        = document.getElementById("m-fade-left");
  const mFadeRight       = document.getElementById("m-fade-right");

  function updateMobileFades() {
    if (!mobileShelfTrack) return;
    const { scrollLeft, scrollWidth, clientWidth } = mobileShelfTrack;
    if (mFadeLeft)  mFadeLeft.style.opacity  = scrollLeft > 4 ? "1" : "0";
    if (mFadeRight) mFadeRight.style.opacity = scrollLeft + clientWidth < scrollWidth - 4 ? "1" : "0";
  }

  mobileShelfTrack?.addEventListener("scroll", updateMobileFades, { passive: true });

  // Initialise fade visibility after layout
  requestAnimationFrame(() => { updateFades(); updateMobileFades(); });
</script>
